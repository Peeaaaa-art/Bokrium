<nav class="navbar shadow-sm border-bottom py-2 px-3 bg-apple-light">
  <div class="container-fluid d-flex justify-content-between align-items-center" style="min-height: 72px;">
    <% current_path = request.path %>
    <% logo_path = user_signed_in? ? random_memo_path : root_path %>

    <!-- 左：ロゴ -->
    <%= link_to logo_path, class: "navbar-brand rounded #{current_page?(logo_path) ? 'active' : ''}", style: "letter-spacing: 0.03em;", title: (user_signed_in? ? "ランダムメモ" : "ホーム") do %>
      <%= bi_icon("bokrium_logo", css: "logo-icon") %>
    <% end %>

    <!-- 中央：ナビアイコン -->
    <div class="d-flex align-items-center justify-content-evenly flex-grow-1" style="max-width: 360px;">
      <% icons = [
        { path: search_books_path, icon: "search_header", title: "書籍検索", active: current_path.starts_with?('/search') },
        { path: books_index_path, icon: "library-big", title: (user_signed_in? && current_user.books.exists? ? "本棚" : "サンプル本棚"), active: books_index_active_class.present? }
      ] %>
      <% if user_signed_in? %>
        <% icons << { path: reading_board_path, icon: "calendar-check", title: "読書戦略ボード", active: current_path.starts_with?('/reading_board') } %>
      <% end %>

      <% icons.each do |item| %>
<%= link_to item[:path],
            class: "text-dark #{item[:active] ? 'active' : ''}",
            title: item[:title],
            data: { bs_toggle: "tooltip", bs_placement: "bottom" } do %>
  <div class="d-flex align-items-center justify-content-center" style="width: 44px; height: 44px;">
    <%= bi_icon(item[:icon], css: "", style: "width: 24px; height: 24px; display: block;") %>
  </div>
<% end %>
      <% end %>
    </div>

    <!-- 右：アバター or ログイン -->
    <div class="d-flex align-items-center">
      <% if user_signed_in? %>
        <%= link_to mypage_path do %>
          <%= lazy_image_tag user_avatar(current_user, size: 36), class: "rounded-circle shadow-sm ms-2", style: "width: 48px; height: 48px; object-fit: cover;" %>
        <% end %>
      <% else %>
        <%= link_to 'ログイン', new_user_session_path, class: "btn btn-outline-dark btn-sm" %>
      <% end %>
    </div>
  </div>
</nav>
